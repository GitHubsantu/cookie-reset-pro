{
  "manifest_version": 2,
  "name": "Cookie Reset Pro",
  "short_name": "Cookie Reset Pro",
  "version": "1.0.0",
  "author": "Dharanidhar Mahata (imdevops)",
  "homepage_url": "https://imdevops.in",
  "description": "Advanced privacy extension that clears all tracking data before and during navigation",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "webNavigation",
    "browsingData",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["browser-polyfill.js", "background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": ["injected.js"],
  "browser_specific_settings": {
    "gecko": {
      "id": "cookie-reset-pro@imdevops.in",
      "strict_min_version": "109.0"
    }
  }
}
